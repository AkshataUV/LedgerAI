# ─────────────────────────────────────────────
# Supabase Configuration
# ─────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # Keep secret — admin use only

# ─────────────────────────────────────────────
# Internal Communication
# ─────────────────────────────────────────────
INTERNAL_SECRET=your_internal_shared_secret
NODE_BACKEND_URL=http://127.0.0.1:3000
PYTHON_PORT=5000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Public URL of this parser_backend on Render (used by work-mode keep-alive
# so the service can ping itself every 10 min during long tasks).
# Leave blank on localhost — the keep-alive is skipped automatically.
SELF_URL=https://your-parser-backend.onrender.com

# ─────────────────────────────────────────────
# Gemini AI Configuration
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
CLASSIFIER_MODEL=models/gemini-2.5-flash
LLM_PARSER_MODEL=models/gemini-2.5-flash

# ─────────────────────────────────────────────
# Code Generation LLM
# ─────────────────────────────────────────────
CODE_GEN_PROVIDER=openrouter                 # openrouter | anthropic | 9router

# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-sonnet-4-5-20241022

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# ─────────────────────────────────────────────
# LLM Settings
# ─────────────────────────────────────────────
CODE_GEN_MAX_TOKENS=4096
CODE_GEN_TEMPERATURE=0
